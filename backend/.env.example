# Copy this to .env and fill in values

# Database (local dev)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/proteindb

# Redis (local dev)
REDIS_URL=redis://localhost:6379

# NCBI API key (optional, increases rate limits for ClinVar)
# Get free key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Debug mode
DEBUG=false
